<Project Sdk="Microsoft.NET.Sdk">

    <PropertyGroup>
        <TargetFramework>net9.0</TargetFramework>
        <Nullable>enable</Nullable>
        <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
        <GenerateDocumentationFile>true</GenerateDocumentationFile>
        <RootNamespace>SampSharp.Streamer.Entities</RootNamespace>
        <AssemblyName>SampSharp.OpenMp.Streamer</AssemblyName>
    </PropertyGroup>

    <!--
        Depends on openmp-sampsharp-x64-poc which lives as a sibling submodule.
        When this repo is consumed standalone (без VSRP), переопредели пути через
        Directory.Build.props или консьюмер-проекту надо самому добавить нужные
        ProjectReference'ы.
    -->
    <ItemGroup>
        <ProjectReference Include="..\openmp-sampsharp-x64-poc\src\SampSharp.OpenMp.Core\SampSharp.OpenMp.Core.csproj" />
        <ProjectReference Include="..\openmp-sampsharp-x64-poc\src\SampSharp.OpenMp.Entities\SampSharp.OpenMp.Entities.csproj" />
    </ItemGroup>

</Project>
